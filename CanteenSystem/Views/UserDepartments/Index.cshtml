@model IEnumerable<CanteenSystem.Models.UserDepartment>

@{
    ViewBag.Title = "Danh sách gán user - bộ phận";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0"><i class="fas fa-user-check"></i> Danh sách gán user - bộ phận</h4>
                </div>
                <div class="card-body">

                    <p>
                        <a href="@Url.Action("Create")" class="btn btn-success">
                            <i class="fas fa-plus"></i> Gán user cho bộ phận
                        </a>
                    </p>

                    <div class="table-responsive">
                        <table class="table table-striped table-hover">
                            <thead class="thead-dark">
                                <tr>
                                    <th>User (Tên đăng nhập)</th>
                                    <th>Bộ phận (Mã - Tên)</th>
                                    <th>Thao tác</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td>@Html.DisplayFor(modelItem => item.User.Username)</td>
                                        <td>@Html.DisplayFor(modelItem => item.Department.DepartmentCode) - @Html.DisplayFor(modelItem => item.Department.DepartmentName)</td>
                                        <td>
                                            <a href="@Url.Action("Delete", new { userId = item.UserId, departmentId = item.DepartmentId })" class="btn btn-sm btn-danger">
                                                <i class="fas fa-trash"></i> Xóa gán
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    @if (!Model.Any())
                    {
                        <div class="alert alert-info">Chưa có gán user - bộ phận nào. Hãy thêm mới!</div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>