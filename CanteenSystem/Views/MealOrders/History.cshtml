@model IEnumerable<CanteenSystem.Models.MealOrder>

@{
    ViewBag.Title = "Lịch sử báo cơm bộ phận - " + ViewBag.SelectedDate.ToString("dd/MM/yyyy");
    var selectedDate = (DateTime)ViewBag.SelectedDate;
}
<div class="content">
    <div class="container-fluid">
        <div class="card">
            <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                <h4 class="mb-0"><i class="fas fa-history"></i> Lịch sử báo cơm bộ phận</h4>
                
            </div>
            <div class="card-body">
                <!-- Dropdown chọn ngày -->
                <div class="mb-3">
                    <input type="text"
                           id="datePicker"
                           class="form-control"
                           value="@ViewBag.SelectedDate.ToString("yyyy-MM-dd")" />
                </div>

                <!-- Bảng dữ liệu -->
                <div class="table-responsive">
                    <table class="table table-bordered table-hover">
                        <thead class="thead-dark">
                            <tr>
                                <th>Bộ phận</th>
                                <th>Ngày</th>
                                <th>Ca làm</th>
                                <th>Món ăn</th>
                                <th>Nhà ăn</th>
                                <th>Số lượng</th>
                                <th>Loại nhân sự</th>
                                <th>Tổng tiền</th>
                                <th>Người tạo</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>@(item.Department?.DepartmentName)</td>
                                    <td>@item.Date.ToString("dd/MM/yyyy")</td>
                                    <td>@item.Shift</td>
                                    <td>@(item.Meal?.MealName)</td>
                                    <td>@(item.Kitchen?.KitchenName)</td>
                                    <td>@item.Quantity</td>
                                    <td>@item.PersonnelType</td>
                                    <td>@item.Price.ToString("N0")</td>
                                    <td>@item.Creator</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <a href="@Url.Action("Create")" class="btn btn-success">
                    <i class="fas fa-plus"></i> Báo cơm mới
                </a>

                @if (!Model.Any())
                {
                    <div class="alert alert-info text-center">
                        Chưa có báo cơm nào cho ngày @selectedDate.ToString("dd/MM/yyyy").
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")

    <script>

    flatpickr("#datePicker", {

        dateFormat: "Y-m-d",

        defaultDate: "@ViewBag.SelectedDate.ToString("yyyy-MM-dd")",

        onChange: function(selectedDates, dateStr) {

            window.location.href = '/MealOrders/History?date=' + dateStr;

        }

    });

    </script>
}