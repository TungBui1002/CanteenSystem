@model IEnumerable<CanteenSystem.Models.MealOrder>

@{
    ViewBag.Title = "Lịch sử báo cơm bộ phận - " + ViewBag.SelectedDate.ToString("dd/MM/yyyy");
}

<div class="container-fluid">
    <div class="card">
        <div class="card-header bg-primary text-white">
            <h4><i class="fas fa-history"></i> Lịch sử báo cơm bộ phận - @ViewBag.SelectedDate.ToString("dd/MM/yyyy")</h4>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered table-hover">
                    <thead class="thead-dark">
                        <tr>
                            <th>Bộ phận</th>
                            <th>Ngày</th>
                            <th>Ca làm</th>
                            <th>Món ăn</th>
                            <th>Nhà ăn</th>
                            <th>Số lượng</th>
                            <th>Loại nhân sự</th>
                            <th>Tổng tiền</th>
                            <th>Người tạo</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.Department.DepartmentName</td>
                                <td>@item.Date.ToString("dd/MM/yyyy")</td>
                                <td>@item.Shift</td>
                                <td>@item.Meal.MealName</td>
                                <td>@item.Kitchen.KitchenName</td>
                                <td>@item.Quantity</td>
                                <td>@item.PersonnelType</td>
                                <td>@item.Price.ToString("N0")</td>
                                <td>@item.Creator</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="text-center mt-4">
                <a href="@Url.Action("Create")" class="btn btn-success">Báo cơm mới</a>
            </div>
        </div>
    </div>
</div>