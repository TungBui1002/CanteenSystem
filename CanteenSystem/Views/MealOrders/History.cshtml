@model IEnumerable<CanteenSystem.Models.MealOrder>

@{
    ViewBag.Title = "Lịch sử báo cơm bộ phận - " + ViewBag.SelectedDate.ToString("dd/MM/yyyy");
    var selectedDate = (DateTime)ViewBag.SelectedDate;
    bool isAdmin = Session["Role"]?.ToString() == "Admin";
}
<div class="content">
    <div class="container-fluid">
        <div class="card">
            <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                <h4 class="mb-0"><i class="fas fa-history"></i> Lịch sử báo cơm bộ phận</h4>
                <a href="@Url.Action("Create")" class="btn btn-success">
                    <i class="fas fa-plus"></i> Báo cơm mới
                </a>
            </div>
            <div class="card-body">
                <div class="row mb-4">
                    <div class="col-md-3">
                        <input type="text" id="datePicker" class="form-control" value="@ViewBag.SelectedDate.ToString("yyyy-MM-dd")" />
                    </div>
                    <div class="col-md-1 text-right align-self-end">
                        <form method="post" action="@Url.Action("ExportDailyMeal", "MealOrders")" style="display:inline;">
                            @Html.Hidden("date", ((DateTime)ViewBag.SelectedDate).ToString("yyyy-MM-dd"))
                            <button type="submit" class="btn btn-success">
                                <i class="fas fa-file-excel"></i> Xuất Excel
                            </button>
                        </form>
                    </div>
                    <div class="col-md-8">
                        <form method="get" style="display:flex; gap:8px;">
                            @Html.Hidden("date", ((DateTime)ViewBag.SelectedDate).ToString("yyyy-MM-dd"))
                            <input type="text" name="search" class="form-control" placeholder="Nhập mã hoặc tên bộ phận..." value="@ViewBag.Search" />
                            <button type="submit" class="btn btn-primary"><i class="fas fa-search"></i> Tìm</button>
                            @if (!string.IsNullOrEmpty(ViewBag.Search))
                            {
                                <a href="@Url.Action("History", new { date = ViewBag.SelectedDate })" class="btn btn-secondary">Xóa</a>
                            }
                        </form>
                    </div>
                </div>

                <!-- Bảng dữ liệu -->
                <div class="table-responsive">
                    <table class="table table-bordered table-hover">
                        <thead class="thead-dark">
                            <tr>
                                <th>TT Chi Phí</th>
                                <th>Mã bộ phận</th>
                                <th>Bộ phận</th>
                                <th>Ngày</th>
                                <th>Ca làm</th>
                                <th>Giờ ăn</th>
                                <th>Món ăn</th>
                                <th>Nhà ăn</th>
                                <th>Số lượng</th>
                                <th>Loại nhân sự</th>
                                <th>Tổng tiền</th>
                                <th>Người tạo</th>
                                <th>Người sửa</th>
                                @if (isAdmin)
                                {
                                    <th>Thao tác</th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>@(item.Department?.CostCenter)</td>
                                    <td>@(item.Department?.DepartmentCode)</td>
                                    <td>@(item.Department?.DepartmentName)</td>
                                    <td>@item.Date.ToString("dd/MM/yyyy")</td>
                                    <td>@item.Shift</td>
                                    <td>@item.Time</td>
                                    <td>@(item.Meal?.MealName)</td>
                                    <td>@(item.Kitchen?.KitchenName)</td>
                                    <td>@item.Quantity</td>
                                    <td>@item.PersonnelType</td>
                                    <td>@item.Price.ToString("N0")</td>
                                    <td>@item.Creator</td>
                                    <td>@item.Modifier</td>
                                    @if (isAdmin)
                                    {
                                        <td>
                                            <a href="@Url.Action("Edit", new { id = item.OrderId })" class="btn btn-sm btn-warning">
                                                <i class="fas fa-edit"></i> Sửa
                                            </a>
                                            <a href="@Url.Action("Delete", new { id = item.OrderId, date = item.Date })" class="btn btn-sm btn-danger">
                                                <i class="fas fa-trash"></i> Xóa
                                            </a>
                                        </td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                @if (!Model.Any())
                {
                    <div class="alert alert-info text-center">
                        Chưa có báo cơm nào cho ngày @selectedDate.ToString("dd/MM/yyyy").
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")

    <script>

    flatpickr("#datePicker", {

        dateFormat: "Y-m-d",

        defaultDate: "@ViewBag.SelectedDate.ToString("yyyy-MM-dd")",

        onChange: function(selectedDates, dateStr) {

            window.location.href = '/MealOrders/History?date=' + dateStr;

        }

    });

    </script>
}