@model CanteenSystem.Models.MealOrder

@{
    ViewBag.Title = "Đặt cơm bộ phận - " + ViewBag.SelectedDate.ToString("dd/MM/yyyy");
}

<style>
    .meal-form-wrapper {
        background: linear-gradient(135deg, #f5f7fa 0%, #f9fafb 100%);
        min-height: 100vh;
        padding: 40px 20px;
    }

    .meal-card {
        background: white;
        border-radius: 16px;
        box-shadow: 0 4px 24px rgba(0, 0, 0, 0.08);
        overflow: hidden;
    }

    .meal-header {
        background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%);
        color: white;
        padding: 32px;
        display: flex;
        align-items: center;
        gap: 16px;
    }

    .meal-body {
        padding: 40px;
    }

    .dynamic-row {
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        padding: 20px;
        margin-bottom: 20px;
        position: relative;
    }

    .remove-row-btn {
        position: absolute;
        top: 12px;
        right: 12px;
        color: #ef4444;
        cursor: pointer;
        font-size: 18px;
    }

    .form-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 18px;
    }

    .sticky-actions {
        position: sticky;
        bottom: 0;
        background: white;
        padding: 16px;
        border-top: 1px solid #e5e7eb;
        text-align: center;
        z-index: 10;
    }

    .form-control:focus {
        border-color: #22c55e;
        box-shadow: 0 0 0 2px rgba(34,197,94,0.2);
    }
</style>

<div class="content">
    <div class="meal-form-wrapper">
        <div class="container-fluid" style="max-width: 100%; margin: 0 auto;">
            <div class="meal-card">
                <div class="meal-header">
                    <div style="flex:1">
                        <h4 class="mb-0">Đặt cơm bộ phận - @ViewBag.SelectedDate.ToString("dd/MM/yyyy")</h4>
                    </div>
                    <a href="@Url.Action("History")" class="btn btn-light">
                        <i class="fas fa-history"></i>Xem Lịch sử
                    </a>
                </div>

                <div class="meal-body">
                    @using (Html.BeginForm("Create", "MealOrders", FormMethod.Post))
                    {
                        @Html.AntiForgeryToken()

                        <div id="meal-rows">
                            <!-- Dòng đầu tiên -->
                            <div class="dynamic-row" data-index="0">
                                <button type="button" class="remove-row-btn" onclick="removeRow(this)">×</button>

                                <div class="form-grid">
                                    <div>
                                        @Html.Label("DepartmentId_0", "Bộ phận")
                                        @Html.DropDownList("DepartmentId[0]", (SelectList)ViewBag.DepartmentId, "-- Chọn bộ phận --", new { @class = "form-control" })
                                    </div>

                                    <div>
                                        @Html.Label("Shift_0", "Ca làm việc")
                                        @Html.DropDownList("Shift[0]", (SelectList)ViewBag.Shift, "-- Chọn ca --", new { @class = "form-control shift-select" })
                                    </div>

                                    <div>
                                        @Html.Label("Time_0", "Thời gian ăn")
                                        @Html.DropDownList("Time[0]", new SelectList(new string[0]), "-- Chọn giờ --", new { @class = "form-control time-select" })
                                    </div>

                                    <div>
                                        @Html.Label("MealId_0", "Món ăn")
                                        @Html.DropDownList("MealId[0]", (SelectList)ViewBag.MealId, "-- Chọn món --", new { @class = "form-control" })
                                    </div>

                                    <div>
                                        @Html.Label("KitchenId_0", "Nhà ăn")
                                        @Html.DropDownList("KitchenId[0]", (SelectList)ViewBag.KitchenId, "-- Chọn nhà ăn --", new { @class = "form-control" })
                                    </div>

                                    <div>
                                        @Html.Label("PersonnelType_0", "Loại nhân sự")
                                        @Html.DropDownList("PersonnelType[0]", (SelectList)ViewBag.PersonnelType, "-- Chọn loại --", new { @class = "form-control" })
                                    </div>

                                    <div>
                                        @Html.Label("Quantity_0", "Số lượng (phần)")
                                        <input type="number" name="Quantity[0]" value="1" min="1" class="form-control" />
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Server-rendered template with placeholder __INDEX__ -->
                        <script type="text/template" id="row-template">
                            <div class="dynamic-row" data-index="__INDEX__">
                                <button type="button" class="remove-row-btn" onclick="removeRow(this)">×</button>
                                <div class="form-grid">
                                    <div>
                                        @Html.DropDownList("DepartmentId[__INDEX__]", (SelectList)ViewBag.DepartmentId, "-- Chọn bộ phận --", new { @class = "form-control" })
                                    </div>
                                    <div>
                                        @Html.DropDownList("Shift[__INDEX__]", (SelectList)ViewBag.Shift, "-- Chọn ca --", new { @class = "form-control shift-select" })
                                    </div>
                                    <div>
                                        <select name="Time[__INDEX__]" class="form-control time-select">
                                            <option value="">-- Chọn giờ --</option>
                                        </select>
                                    </div>
                                    <div>
                                        @Html.DropDownList("MealId[__INDEX__]", (SelectList)ViewBag.MealId, "-- Chọn món --", new { @class = "form-control" })
                                    </div>
                                    <div>
                                        @Html.DropDownList("KitchenId[__INDEX__]", (SelectList)ViewBag.KitchenId, "-- Chọn nhà ăn --", new { @class = "form-control" })
                                    </div>
                                    <div>
                                        @Html.DropDownList("PersonnelType[__INDEX__]", (SelectList)ViewBag.PersonnelType, "-- Chọn loại --", new { @class = "form-control" })
                                    </div>
                                    <div>
                                        <input type="number" name="Quantity[__INDEX__]" value="1" min="1" class="form-control" />
                                    </div>
                                </div>
                            </div>
                        </script>

                        <div class="sticky-actions">
                            <button type="button" id="add-row" class="btn btn-info">
                                <i class="fas fa-plus"></i> Thêm dòng
                            </button>
                            <input type="submit" value="Xác nhận báo cơm" class="btn btn-success btn-lg ml-3" />
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")

<script>
        let rowIndex = 1;

        function addRow() {
            const container = document.getElementById('meal-rows');
            const template = document.getElementById('row-template').innerHTML;
            const html = template.replace(/__INDEX__/g, rowIndex);

            const temp = document.createElement('div');
            temp.innerHTML = html.trim();
            const newRow = temp.firstElementChild;
            container.appendChild(newRow);

            // Attach event for shift -> time update
            const shiftSelect = newRow.querySelector('.shift-select');
            if (shiftSelect) {
                shiftSelect.addEventListener('change', updateTimeOptions);
            }

            // Attach event for time -> meal update
            const timeSelect = newRow.querySelector('.time-select');
            if (timeSelect) {
                timeSelect.addEventListener('change', function () {
                    updateMealOptions(newRow);
                });
            }

            rowIndex++;
        }

        function removeRow(btn) {
            if (document.querySelectorAll('.dynamic-row').length <= 1) return;

            if (confirm("Xóa dòng này?")) {
                btn.closest('.dynamic-row').remove();
                updateRowIndex();
            }
        }

        function updateTimeOptions(e) {
            const shift = e.target.value;
            const timeSelect = e.target.closest('.dynamic-row').querySelector('.time-select');
            timeSelect.innerHTML = '<option value="">-- Chọn giờ --</option>';

            const timeOptions = @Html.Raw(Json.Encode(ViewBag.TimeOptions));

            if (timeOptions && timeOptions[shift]) {
                timeOptions[shift].forEach(time => {
                    const opt = document.createElement('option');
                    opt.value = time;
                    opt.textContent = time;
                    timeSelect.appendChild(opt);
                });
            }
        }

        function updateMealOptions(row) {
            const shift = row.querySelector('.shift-select').value;
            const time = row.querySelector('.time-select').value;
            const mealSelect = row.querySelector('select[name^="MealId"]');

            const mealOptions = @Html.Raw(Json.Encode(ViewBag.MealOptions));
            const allMeals = @Html.Raw(Json.Encode(ViewBag.MealId));

            mealSelect.innerHTML = '<option value="">-- Chọn món --</option>';

            if (!shift || !time) return;

            const allowedMeals = mealOptions?.[shift]?.[time];
            if (!allowedMeals) return;

            allMeals.forEach(meal => {
                if (allowedMeals.includes(meal.Text)) {
                    const opt = document.createElement('option');
                    opt.value = meal.Value;
                    opt.textContent = meal.Text;
                    mealSelect.appendChild(opt);
                }
            });
        }

        document.addEventListener('change', function (e) {
            if (e.target.classList.contains('time-select')) {
                const row = e.target.closest('.dynamic-row');
                updateMealOptions(row);
            }
        });

        //loading khi submit form
        document.querySelector("form").addEventListener("submit", function () {
            const btn = document.querySelector('input[type="submit"]');
            btn.value = "Đang xử lý...";
            btn.disabled = true;
        });

        // Khởi tạo cho dòng đầu tiên
        document.addEventListener('DOMContentLoaded', function () {
            document.getElementById('add-row').addEventListener('click', addRow);

            const firstShift = document.querySelector('.shift-select');
            if (firstShift) {
                firstShift.addEventListener('change', updateTimeOptions);
                firstShift.dispatchEvent(new Event('change'));
            }
        });
</script>
}