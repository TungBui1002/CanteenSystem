@model CanteenSystem.Models.MealOrder

@{
    ViewBag.Title = "Xóa báo cơm bộ phận";
}

<div class="content">
    <div class="container-fluid">
        <div class="card">
            <div class="card-header bg-danger text-white">
                <h4><i class="fas fa-trash"></i> Xác nhận xóa báo cơm</h4>
            </div>
            <div class="card-body">
                <h3>Bạn có chắc chắn muốn xóa báo cơm này?</h3>
                <dl class="dl-horizontal">
                    <dt>Bộ phận</dt>
                    <dd>@(Model.Department?.DepartmentName ?? "Chưa gán")</dd>

                    <dt>Ngày</dt>
                    <dd>@Model.Date.ToString("dd/MM/yyyy")</dd>

                    <dt>Ca làm</dt>
                    <dd>@Model.Shift</dd>

                    <dt>Món ăn</dt>
                    <dd>@(Model.Meal?.MealName ?? "-")</dd>

                    <dt>Nhà ăn</dt>
                    <dd>@(Model.Kitchen?.KitchenName ?? "-")</dd>

                    <dt>Số lượng</dt>
                    <dd>@Model.Quantity</dd>

                    <dt>Loại nhân sự</dt>
                    <dd>@Model.PersonnelType</dd>

                    <dt>Tổng tiền</dt>
                    <dd>@Model.Price.ToString("N0") VNĐ</dd>

                    <dt>Người tạo</dt>
                    <dd>@Model.Creator</dd>
                </dl>

                @using (Html.BeginForm())
                {
                    @Html.AntiForgeryToken()
                    @Html.HiddenFor(model => model.OrderId)

                    <div class="form-actions no-color">
                        <input type="submit" value="Xóa" class="btn btn-danger" />
                        <a href="@Url.Action("History", new { date = Model.Date })" class="btn btn-secondary ml-2">Hủy</a>
                    </div>
                }
            </div>
        </div>
    </div>
</div>