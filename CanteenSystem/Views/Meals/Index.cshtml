@model IEnumerable<CanteenSystem.Models.Meal>

@{
    ViewBag.Title = "Meals";
}
<div class="content">
    <div class="container-fluid">
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header bg-primary text-white">
                        <h4 class="mb-0"><i class="fas fa-utensils"></i> Danh sách món ăn</h4>
                    </div>
                    <div class="card-body">
                        
                        <p>
                            <a href="@Url.Action("Create")" class="btn btn-success">
                                <i class="fas fa-plus"></i> Thêm món ăn mới
                            </a>
                            <a>Lưu ý: Department: Bộ phận | Leader: Cán bộ</a>
                        </p>

                        <div class="table-responsive">
                            <table class="table table-striped table-hover">
                                <thead class="thead-dark">
                                    <tr>
                                        <th>@Html.DisplayNameFor(model => model.MealName)</th>
                                        <th>@Html.DisplayNameFor(model => model.Price)</th>
                                        <th>@Html.DisplayNameFor(model => model.ApplicableFor)</th>
                                        <th>Thao tác</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model)
                                    {
                                        <tr>
                                            <td>@Html.DisplayFor(modelItem => item.MealName)</td>
                                            <td>@Html.DisplayFor(modelItem => item.Price, "{0:#,##0} đ")</td>
                                            <td>@Html.DisplayFor(modelItem => item.ApplicableFor)</td>
                                            <td>
                                                <a href="@Url.Action("Edit", new { id = item.MealId })" class="btn btn-sm btn-warning">
                                                    <i class="fas fa-edit"></i> Sửa
                                                </a>
                                                <a href="@Url.Action("Delete", new { id = item.MealId })" class="btn btn-sm btn-danger delete-confirm">
                                                    <i class="fas fa-trash"></i> Xóa
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        @if (!Model.Any())
                        {
                            <div class="alert alert-info">Chưa có món ăn nào. Hãy thêm mới!</div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Confirm xóa ngay tại Index
        document.querySelectorAll('.delete-confirm').forEach(link => {
            link.addEventListener('click', function(e) {
                if (!confirm('Bạn có chắc muốn xóa món "' + this.closest('tr').querySelector('td:first-child').textContent + '" không?')) {
                    e.preventDefault();
                }
            });
        });
    </script>
}