@{
    ViewBag.Title = "Reports";
}

    <div class="container-fluid">
        <div class="content">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h4><i class="fas fa-chart-bar"></i> Hệ thống báo cáo</h4>
                </div>
                <div class="card-body">
                    <div class="row">

                        <!-- Leader Monthly -->
                        <div class="col-md-6">
                            <div class="card border-left-primary shadow h-100">
                                <div class="card-body text-center">

                                    <i class="fas fa-user-tie fa-3x text-primary mb-3"></i>

                                    <h5 class="card-title">
                                        Báo cáo tháng cán bộ
                                    </h5>

                                    <p class="text-muted">
                                        Thống kê suất ăn của cán bộ theo tháng.
                                    </p>

                                    <a href="@Url.Action("LeaderMonthly")" class="btn btn-primary">
                                        <i class="fas fa-file-alt"></i> Xem báo cáo
                                    </a>

                                </div>
                            </div>
                        </div>

                        <!-- Meal Monthly -->
                        <div class="col-md-6">
                            <div class="card border-left-success shadow h-100">
                                <div class="card-body text-center">

                                    <i class="fas fa-utensils fa-3x text-success mb-3"></i>

                                    <h5 class="card-title">
                                        Báo cáo tháng bộ phận
                                    </h5>

                                    <p class="text-muted">
                                        Thống kê số lượng suất ăn toàn bộ phận.
                                    </p>

                                    <a href="@Url.Action("MealMonthly")" class="btn btn-success">
                                        <i class="fas fa-file-alt"></i> Xem báo cáo
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
