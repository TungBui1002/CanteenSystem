@model IEnumerable<CanteenSystem.Models.User>

@{
    ViewBag.Title = "Accounts";
}

<div class="content">
    <div class="container-fluid">
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header bg-primary text-white">
                        <h4 class="mb-0"><i class="fas fa-users"></i> Danh sách người dùng</h4>
                    </div>
                    <div class="card-body">
                        <p>
                            <a href="@Url.Action("Create")" class="btn btn-success">
                                <i class="fas fa-plus"></i> Thêm tài khoản
                            </a>
                        </p>

                        <div class="table-responsive">
                            <table class="table table-striped table-hover">
                                <thead class="thead-dark">
                                    <tr>
                                        <th>STT</th>
                                        <th>Tên đăng nhập</th>
                                        <th>Họ tên</th>
                                        <th>Vai trò</th>
                                        <th>Ngày tạo</th>
                                        <th>Ngày cập nhật</th>
                                        <th>Thao tác</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @{
                                        int Stt = 1;
                                    }
                                    @foreach (var item in Model)
                                    {
                                        <tr>
                                            <td>@Stt</td>
                                            <td>@Html.DisplayFor(modelItem => item.Username)</td>
                                            <td>@Html.DisplayFor(modelItem => item.Fullname)</td>
                                            <td>
                                                <span class="badge @(item.Role == "Admin" ? "badge-danger" : "badge-success")">
                                                    @item.Role
                                                </span>
                                            </td>
                                            <td>@Html.DisplayFor(modelItem => item.CreatedAt)</td>
                                            <td>@(item.UpdatedAt.HasValue ? item.UpdatedAt.Value.ToString() : "-")</td>
                                            <td>
                                                <a href="@Url.Action("Edit", new { id = item.UserId })" class="btn btn-sm btn-warning">
                                                    <i class="fas fa-edit"></i> Sửa
                                                </a>
                                                <a href="@Url.Action("ResetPassword", new { id = item.UserId })" class="btn btn-sm btn-info">
                                                    <i class="fas fa-key"></i> Reset Password
                                                </a>
                                                <a href="@Url.Action("Delete", new { id = item.UserId })" class="btn btn-sm btn-danger">
                                                    <i class="fas fa-trash"></i> Xóa
                                                </a>
                                            </td>
                                        </tr>
                                        Stt++;
                                    }
                                </tbody>
                            </table>
                        </div>

                        @if (!Model.Any())
                        {
                            <div class="alert alert-info">Chưa có người dùng nào. Hãy thêm mới!</div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>