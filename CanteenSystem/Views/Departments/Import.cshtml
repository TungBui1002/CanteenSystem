@{
    ViewBag.Title = "Import departments by Excel";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header bg-info text-white">
                    <h4 class="mb-0"><i class="fas fa-file-excel"></i> Import bộ phận từ Excel</h4>
                </div>
                <div class="card-body">
                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success">@TempData["Success"]</div>
                    }
                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger">@TempData["Error"]</div>
                    }

                    <p>
                        File Excel cần có cấu trúc (sheet 1):
                        <ul>
                            <li>Cột A: DepartmentCode (mã bộ phận)</li>
                            <li>Cột B: DepartmentName (tên bộ phận)</li>
                            <li>Cột C: CostCenter (nếu có)</li>
                            <li>Row 1 là header (bỏ qua)</li>
                        </ul>
                    </p>

                    @using (Html.BeginForm("Import", "Departments", FormMethod.Post, new { enctype = "multipart/form-data" }))
                    {
                        @Html.AntiForgeryToken()

                        <div class="form-group">
                            <label>Chọn file Excel (.xlsx)</label>
                            <input type="file" name="excelFile" class="form-control-file" accept=".xlsx" required />
                        </div>

                        <div class="form-group mt-4">
                            <input type="submit" value="Import ngay" class="btn btn-info" />
                            @Html.ActionLink("Quay lại danh sách", "Index", null, new { @class = "btn btn-secondary ml-2" })
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>