@model IEnumerable<CanteenSystem.Models.Department>

@{
    ViewBag.Title = "Departments";
}

<div class="content">
    <div class="container-fluid">
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header bg-primary text-white">
                        <h4 class="mb-0"><i class="fas fa-building"></i> Danh sách bộ phận</h4>
                    </div>
                    <div class="card-body">
                        <p>
                            <a href="@Url.Action("Create")" class="btn btn-success">
                                <i class="fas fa-plus"></i> Thêm bộ phận mới
                            </a>
                            <a href="@Url.Action("Import")" class="btn btn-info ml-2">
                                <i class="fas fa-file-import"></i> Import từ Excel
                            </a>
                        </p>

                        <!-- Search form -->
                        @using (Html.BeginForm("Index", "Departments", FormMethod.Get, new { @class = "form-inline mb-3" }))
                        {
                            <div class="input-group">
                                <input type="text" name="searchString" class="form-control" placeholder="Tìm theo mã hoặc tên bộ phận..." value="@ViewBag.CurrentFilter" />
                                <div class="input-group-append">
                                    <button type="submit" class="btn btn-primary"><i class="fas fa-search"></i> Tìm</button>
                                </div>
                            </div>
                        }

                        <div class="table-responsive">
                            <table class="table table-striped table-hover">
                                <thead class="thead-dark">
                                    <tr>
                                        <th>@Html.DisplayNameFor(model => model.DepartmentCode)</th>
                                        <th>@Html.DisplayNameFor(model => model.DepartmentName)</th>
                                        <th>@Html.DisplayNameFor(model => model.CostCenter)</th>
                                        <th>Thao tác</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model)
                                    {
                                        <tr>
                                            <td>@Html.DisplayFor(modelItem => item.DepartmentCode)</td>
                                            <td>@Html.DisplayFor(modelItem => item.DepartmentName)</td>
                                            <td>@Html.DisplayFor(modelItem => item.CostCenter)</td>
                                            <td>
                                                <a href="@Url.Action("Edit", new { id = item.DepartmentId })" class="btn btn-sm btn-warning">
                                                    <i class="fas fa-edit"></i> Sửa
                                                </a>
                                                <a href="@Url.Action("Delete", new { id = item.DepartmentId })" class="btn btn-sm btn-danger">
                                                    <i class="fas fa-trash"></i> Xóa
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        @if (!Model.Any())
                        {
                            <div class="alert alert-info">Chưa có bộ phận nào. Hãy thêm mới!</div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

    @section Scripts {
        <script>
            // Optional: confirm delete
            document.querySelectorAll('a.btn-danger').forEach(link => {
                link.addEventListener('click', function (e) {
                    if (!confirm('Bạn có chắc muốn xóa bộ phận này?')) {
                        e.preventDefault();
                    }
                });
            });
        </script>
    }
