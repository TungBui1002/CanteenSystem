@model IEnumerable<CanteenSystem.Models.Leader>

@{
    ViewBag.Title = "Leaders";
}

<div class="content">
    <div class="container-fluid">
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header bg-primary text-white">
                        <h4 class="mb-0"><i class="fas fa-user-tie"></i> Danh sách cán bộ</h4>
                    </div>
                    <div class="card-body">

                        <p>
                            <a href="@Url.Action("Create")" class="btn btn-success">
                                <i class="fas fa-plus"></i> Thêm cán bộ mới
                            </a>
                            <a href="@Url.Action("Import")" class="btn btn-info ml-2">
                                <i class="fas fa-file-import"></i> Import từ Excel
                            </a>
                        </p>

                        <!-- Tìm kiếm -->
                        @using (Html.BeginForm("Index", "Leaders", FormMethod.Get, new { @class = "form-inline mb-3" }))
                        {
                            <div class="input-group">
                                <input type="text" name="searchString" class="form-control" placeholder="Tìm theo mã, tên, chức vụ, bộ phận..." value="@ViewBag.CurrentFilter" />
                                <div class="input-group-append">
                                    <button type="submit" class="btn btn-primary"><i class="fas fa-search"></i> Tìm</button>
                                </div>
                            </div>
                        }

                        <div class="table-responsive">
                            <table class="table table-striped table-hover">
                                <thead class="thead-dark">
                                    <tr>
                                        <th>STT</th>
                                        <th>Mã cán bộ</th>
                                        <th>Họ tên</th>
                                        <th>Bộ phận</th>
                                        <th>Chức vụ</th>
                                        <th>Trung tâm chi phí</th>
                                        <th>Thao tác</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @{
                                        int stt = 1;
                                    }

                                    @foreach (var item in Model)
                                    {
                                        <tr>
                                            <td>@stt</td>
                                            <td>@Html.DisplayFor(modelItem => item.EmployeeId)</td>
                                            <td>@Html.DisplayFor(modelItem => item.FullName)</td>
                                            <td>@Html.DisplayFor(modelItem => item.Department.DepartmentCode) @*- @Html.DisplayFor(modelItem => item.Department.DepartmentName)*@</td>
                                            <td>@Html.DisplayFor(modelItem => item.Rank)</td>
                                            <td>@Html.DisplayFor(modelItem => item.CostCenter)</td>
                                            <td>
                                                <a href="@Url.Action("Edit", new { id = item.EmployeeId })" class="btn btn-sm btn-warning">
                                                    <i class="fas fa-edit"></i> Sửa
                                                </a>
                                                <a href="@Url.Action("Delete", new { id = item.EmployeeId })" class="btn btn-sm btn-danger">
                                                    <i class="fas fa-trash"></i> Xóa
                                                </a>
                                            </td>
                                        </tr>
                                        stt++;
                                    }
                                </tbody>
                            </table>
                        </div>

                        @if (!Model.Any())
                        {
                            <div class="alert alert-info">Chưa có cán bộ nào. Hãy thêm mới hoặc import từ Excel!</div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>