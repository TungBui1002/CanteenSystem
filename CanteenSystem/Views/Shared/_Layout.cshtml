@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - Canteen System</title>
    <link rel="stylesheet" href="styles.css">
    @Styles.Render("~/Content/css")
    @Scripts.Render("~/bundles/modernizr")
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <link href="~/Style/CSS/MainLayout.css" rel="stylesheet" />
</head>
<body>
    <div class="dashboard-container">
        <!-- Sidebar -->
        <aside class="sidebar" id="sidebar">
            <div class="sidebar-header">
                <h1 class="sidebar-title">🏢 Advanced</h1>
                @*<button class="menu-toggle" id="menuToggle">☰</button>*@
            </div>
           
            <nav class="sidebar-nav">

                @{
                    string role = Session["Role"]?.ToString() ?? "";
                    bool isAdmin = role == "Admin";
                }

                @if (isAdmin)
                {
                    <!-- Dashboard -->
                    <button class="nav-item @(currentController == "Dashboard" ? "active" : "")"
                            onclick="location.href='@Url.Action("Index", "Dashboard")'">
                        <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <line x1="6" y1="20" x2="6" y2="10"></line>
                            <line x1="12" y1="20" x2="12" y2="4"></line>
                            <line x1="18" y1="20" x2="18" y2="14"></line>
                        </svg>
                        Dashboard
                    </button>

                    <!-- LeaderOrders -->
                    <button class="nav-item @(currentController == "LeaderOrders" ? "active" : "")"
                            onclick="location.href='@Url.Action("Index", "LeaderOrders")'">
                        <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M9 3h6l2 2h3v16H4V5h3l2-2z" />
                            <path d="M9 12l2 2 4-4" />
                        </svg>
                        Báo cơm cán bộ
                    </button>
                }

                <!-- MealOrders -->
                <button class="nav-item @(currentController == "MealOrders" ? "active" : "")"
                        onclick="location.href='@Url.Action("Index", "MealOrders")'">
                    <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="8" y1="6" x2="21" y2="6" />
                        <line x1="8" y1="12" x2="21" y2="12" />
                        <line x1="8" y1="18" x2="21" y2="18" />
                        <circle cx="3" cy="6" r="1" />
                        <circle cx="3" cy="12" r="1" />
                        <circle cx="3" cy="18" r="1" />
                    </svg>
                    Báo cơm bộ phận
                </button>
                @if (isAdmin)
                {
                    <!-- Leaders -->
                    <button class="nav-item @(currentController == "Leaders" ? "active" : "")"
                            onclick="location.href='@Url.Action("Index", "Leaders")'">
                        <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="12" cy="7" r="4" />
                            <path d="M5.5 21a6.5 6.5 0 0 1 13 0" />
                        </svg>
                        Danh sách cán bộ
                    </button>

                    <!-- Departments -->
                    <button class="nav-item @(currentController == "Departments" ? "active" : "")"
                            onclick="location.href='@Url.Action("Index", "Departments")'">
                        <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <rect x="3" y="7" width="18" height="13" />
                            <path d="M16 3h-8v4h8z" />
                        </svg>
                        Danh sách bộ phận
                    </button>

                    <!-- Meals -->
                    <button class="nav-item @(currentController == "Meals" ? "active" : "")"
                            onclick="location.href='@Url.Action("Index", "Meals")'">
                        <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M3 3v7a4 4 0 0 0 4 4v7" />
                            <path d="M7 3v7" />
                            <path d="M11 3v18" />
                            <path d="M15 3c0 5 6 5 6 10v8" />
                        </svg>
                        Đồ ăn
                    </button>

                    <!-- Kitchens -->
                    <button class="nav-item @(currentController == "Kitchens" ? "active" : "")"
                            onclick="location.href='@Url.Action("Index", "Kitchens")'">
                        <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M3 11l9-8 9 8" />
                            <path d="M5 10v10h14V10" />
                        </svg>
                        Danh sách nhà ăn
                    </button>

                    <!-- Users -->
                    <button class="nav-item @(currentController == "Users" ? "active" : "")"
                            onclick="location.href='@Url.Action("Index", "Users")'">
                        <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="9" cy="7" r="4" />
                            <circle cx="17" cy="7" r="4" />
                            <path d="M2 21a7 7 0 0 1 14 0" />
                            <path d="M14 21a7 7 0 0 1 8 0" />
                        </svg>
                        Danh sách tài khoản
                    </button>

                    <!-- UserDepartments -->
                    <button class="nav-item @(currentController == "UserDepartments" ? "active" : "")"
                            onclick="location.href='@Url.Action("Index", "UserDepartments")'">
                        <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="9" cy="7" r="4" />
                            <path d="M2 21a7 7 0 0 1 14 0" />
                            <circle cx="18" cy="18" r="3" />
                            <path d="M18 15v6M15 18h6" />
                        </svg>
                        Quản lý tài khoản bộ phận
                    </button>

                    <!-- Reports -->
                    <button class="nav-item @(currentController == "Reports" ? "active" : "")"
                            onclick="location.href='@Url.Action("Index", "Reports")'">
                        <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                            <polyline points="14 2 14 8 20 8" />
                            <line x1="8" y1="13" x2="16" y2="13" />
                            <line x1="8" y1="17" x2="16" y2="17" />
                        </svg>
                        Báo cáo
                    </button>
                }

                <!-- Settings -->
                <button class="nav-item" data-section="settings">
                    <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37z" />
                        <path d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                    </svg>
                    Cài đặt
                </button>

                <!-- Logout -->
                <button class="nav-item" onclick="location.href='@Url.Action("Logout", "Account")'">
                    <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" />
                        <polyline points="16 17 21 12 16 7" />
                        <line x1="21" y1="12" x2="9" y2="12" />
                    </svg>
                    Đăng xuất
                </button>
            </nav>
        </aside>

        <!-- Main Content -->
        <main class="main-content">
            <!-- Header -->
            <header class="header">
                @*<div class="header-left">
                        <button class="mobile-menu-btn" id="mobileSidebarToggle">☰</button>
                        <input type="text" class="search-input" placeholder="Search...">
                    </div>*@
                <div class="header-right">
                    @*<button class="notification-btn">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9" />
                                <path d="M13.73 21a2 2 0 0 1-3.46 0" />
                            </svg>
                            <span class="notification-badge">3</span>
                        </button>*@
                    <div class="user-profile">
                        <img src="https://cdn-icons-png.freepik.com/512/17003/17003310.png" alt="User" class="user-avatar">
                        <span class="user-name">Admin</span>
                    </div>
                </div>
            </header>
            @RenderBody()
        </main>
    </div>
    @Scripts.Render("~/bundles/jquery")
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    @*@Scripts.Render("~/bundles/bootstrap")*@
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @Scripts.Render("~/Style/Scripts/MainLayout.js")
    @RenderSection("scripts", required: false)
</body>
</html>
