@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - Dormitory System</title>
    <link rel="stylesheet" href="styles.css">
    @Styles.Render("~/Content/css")
    @Scripts.Render("~/bundles/modernizr")
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <link href="~/Style/CSS/MainLayout.css" rel="stylesheet" />
</head>
<body>
    <div class="dashboard-container">
        <!-- Sidebar -->
        <aside class="sidebar" id="sidebar">
            <div class="sidebar-header">
                <h1 class="sidebar-title">🏢 Advanced</h1>
                @*<button class="menu-toggle" id="menuToggle">☰</button>*@
            </div>

            <nav class="sidebar-nav">
                <!-- Dashboard -->
                <button class="nav-item @(currentController == "Dashboard" ? "active" : "")"
                        onclick="location.href='@Url.Action("Index", "Dashboard")'">
                    <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="6" y1="20" x2="6" y2="10"></line>
                        <line x1="12" y1="20" x2="12" y2="4"></line>
                        <line x1="18" y1="20" x2="18" y2="14"></line>
                    </svg>
                    Dashboard
                </button>

                <!-- Departments -->
                <button class="nav-item @(currentController == "Departments" ? "active" : "")"
                        onclick="location.href='@Url.Action("Index", "Departments")'">
                    <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M3 21h18M3 10h18M5 7l7-5 7 5M4 15h16v6H4z" />
                    </svg>
                    Bộ phận
                </button>

                <!-- Kitchens -->
                <button class="nav-item @(currentController == "Kitchens" ? "active" : "")"
                        onclick="location.href='@Url.Action("Index", "Kitchens")'">
                    <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
                    </svg>
                    Nhà ăn
                </button>

                <!-- Leaders -->
                <button class="nav-item @(currentController == "Leaders" ? "active" : "")"
                        onclick="location.href='@Url.Action("Index", "Leaders")'">
                    <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h-4m-6 0H5" />
                        <path d="M9 7h6M9 11h6" />
                    </svg>
                    Cán bộ
                </button>

                <!-- LeaderOrders -->
                <button class="nav-item @(currentController == "LeaderOrders" ? "active" : "")"
                        onclick="location.href='@Url.Action("Index", "LeaderOrders")'">
                    <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" />
                        <circle cx="9" cy="7" r="4" />
                        <path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75" />
                    </svg>
                    Đặt cơm cán bộ
                </button>

                <!-- Meals -->
                <button class="nav-item @(currentController == "Meals" ? "active" : "")"
                        onclick="location.href='@Url.Action("Index", "Meals")'">
                    <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    Đồ ăn
                </button>

                <!-- MealOrders -->
                <button class="nav-item @(currentController == "MealOrders" ? "active" : "")"
                        onclick="location.href='@Url.Action("Index", "MealOrders")'">
                    <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    Đặt đồ ăn công nhân
                </button>

                <!-- Users -->
                <button class="nav-item @(currentController == "Users" ? "active" : "")"
                        onclick="location.href='@Url.Action("Index", "Users")'">
                    <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    Người dùng
                </button>

                <!-- UserDepartments -->
                <button class="nav-item @(currentController == "UserDepartments" ? "active" : "")"
                        onclick="location.href='@Url.Action("Index", "UserDepartments")'">
                    <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    Người dùng bộ phận
                </button>
                
                <!-- Settings -->
                <button class="nav-item" data-section="settings">
                    <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37z" />
                        <path d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                    </svg>
                    Cài đặt
                </button>
            </nav>
        </aside>

        <!-- Main Content -->
        <main class="main-content">
            <!-- Header -->
            <header class="header">
                @*<div class="header-left">
                        <button class="mobile-menu-btn" id="mobileSidebarToggle">☰</button>
                        <input type="text" class="search-input" placeholder="Search...">
                    </div>*@
                <div class="header-right">
                    @*<button class="notification-btn">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9" />
                                <path d="M13.73 21a2 2 0 0 1-3.46 0" />
                            </svg>
                            <span class="notification-badge">3</span>
                        </button>*@
                    <div class="user-profile">
                        <img src="https://cdn-icons-png.freepik.com/512/17003/17003310.png" alt="User" class="user-avatar">
                        <span class="user-name">Admin</span>
                    </div>
                </div>
            </header>
            @RenderBody()
        </main>
    </div>
    @Scripts.Render("~/bundles/jquery")
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    @*@Scripts.Render("~/bundles/bootstrap")*@
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @Scripts.Render("~/Style/Scripts/MainLayout.js")
    @RenderSection("scripts", required: false)
</body>
</html>
