@model IEnumerable<CanteenSystem.Models.Leader>

@{
    ViewBag.Title = "Báo cơm cán bộ ngày " + ViewBag.SelectedDate.ToString("dd/MM/yyyy");
    var meals = (IEnumerable<CanteenSystem.Models.Meal>)ViewBag.Meals;
}

<div class="content">
    <div class="container-fluid">
        <div class="card">
            <div class="card-header bg-primary text-white">
                <h4><i class="fas fa-user-tie"></i> Báo cơm cán bộ - @ViewBag.SelectedDate.ToString("dd/MM/yyyy")</h4>
            </div>
            <div class="card-body">
                @using (Html.BeginForm("Create", "LeaderOrders", FormMethod.Post))
                {
                    @Html.AntiForgeryToken()
                    @Html.Hidden("selectedDate", (DateTime)ViewBag.SelectedDate)

                    <div class="table-responsive">
                        <table class="table table-bordered table-hover">
                            <thead class="thead-dark">
                                <tr>
                                    <th>STT</th>
                                    <th>Mã cán bộ</th>
                                    <th>Họ tên</th>
                                    <th>Bộ phận</th>
                                    <th>Chọn món</th>
                                    <th>Trạng thái</th>
                                </tr>
                            </thead>
                            <tbody>
                                @{
                                    int stt = 1;
                                }
                                @for (int i = 0; i < Model.Count(); i++)
                                {
                                    var leader = Model.ElementAt(i);
                                    <tr>
                                        <td>@stt</td>
                                        <td>@leader.EmployeeId</td>
                                        <td>@leader.FullName</td>
                                        <td>@(leader.Department?.DepartmentName ?? "Chưa gán")</td>
                                        <td>
                                            @Html.DropDownList("mealIds[" + i + "]", new SelectList(meals, "MealId", "MealName"), "-- Chọn món --", new { @class = "form-control" })
                                        </td>
                                        <td>
                                            <select name="statuses[@i]" class="form-control">
                                                <option value="Đặt">Đặt</option>
                                                <option value="Chưa đặt">Chưa đặt</option>
                                            </select>
                                        </td>
                                    </tr>
                                    stt++;
                                }
                            </tbody>
                        </table>
                    </div>

                    <div class="text-center mt-4">
                        <button type="submit" class="btn btn-success btn-lg">
                            <i class="fas fa-save"></i> Xác nhận lưu báo cơm ngày hôm nay
                        </button>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}