@model IEnumerable<CanteenSystem.Models.Leader>

@{
    ViewBag.Title = "Báo cơm cán bộ ngày " + ViewBag.SelectedDate.ToString("dd/MM/yyyy");
    var meals = (SelectList)ViewBag.Meals;
}

<div class="container-fluid">
    <div class="card">
        <div class="card-header bg-primary text-white">
            <h4><i class="fas fa-user-tie"></i> Báo cơm cán bộ - @ViewBag.SelectedDate.ToString("dd/MM/yyyy")</h4>
        </div>
        <div class="card-body">
            @using (Html.BeginForm("Create", "LeaderOrders", FormMethod.Post))
            {
                @Html.AntiForgeryToken()
                @Html.Hidden("selectedDate", (DateTime)ViewBag.SelectedDate)

                <table class="table table-bordered table-hover">
                    <thead class="thead-dark">
                        <tr>
                            <th>Trung tâm chi phí</th>
                            <th>Mã cán bộ</th>
                            <th>Họ tên</th>
                            <th>Chức vụ</th>
                            <th>Bộ phận</th>
                            <th>Chọn món</th>
                            <th>Trạng thái</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (int i = 0; i < Model.Count(); i++)
                        {
                            var leader = Model.ElementAt(i);
                            <tr>
                                <td>@leader.CostCenter</td>
                                <td>@leader.EmployeeId</td>
                                <td>@leader.FullName</td>
                                <td>@leader.Rank</td>
                                <td>@leader.Department.DepartmentName</td>
                                <td>
                                    @Html.DropDownList("mealIds[" + i + "]", meals, "-- Chọn món --", new { @class = "form-control" })
                                </td>
                                <td>
                                    <select name="statuses[@i]" class="form-control">
                                        <option value="Chưa đặt">Chưa đặt</option>
                                        <option value="Đặt">Đặt</option>
                                    </select>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>

                <div class="text-center mt-4">
                    <button type="submit" class="btn btn-success btn-lg">
                        <i class="fas fa-save"></i> Xác nhận lưu báo cơm ngày hôm nay
                    </button>
                </div>
            }
        </div>
    </div>
</div>