@model IEnumerable<CanteenSystem.Models.ViewModel.LeaderOrderViewModel>

@{
    ViewBag.Title = "Danh sách báo cơm cán bộ";
    var selectedDate = (DateTime)ViewBag.SelectedDate;
}

<div class="content">
    <div class="container-fluid">
        <div class="card">
            <div class="card-header bg-info text-white d-flex justify-content-between align-items-center">
                <h4 class="mb-0"><i class="fas fa-list"></i> Báo cơm cán bộ - @selectedDate.ToString("dd/MM/yyyy")</h4>
            </div>
            <div class="card-body">

                <!-- Lọc ngày + nút Create -->
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div class="form-group">
                        <div class="mb-3">
                            <input type="text"
                                   id="datePicker"
                                   class="form-control"
                                   value="@ViewBag.SelectedDate.ToString("yyyy-MM-dd")" />
                        </div>
                    </div>
                    <a href="@Url.Action("Create")" class="btn btn-success">
                        <i class="fas fa-plus"></i> Báo cơm mới
                    </a>
                </div>

                <!-- Thông báo ngày hôm nay chưa đặt -->
                @if (ViewBag.NoOrderToday != null)
                {
                    <div class="alert alert-warning text-center">
                        <h5>Hôm nay (@selectedDate.ToString("dd/MM/yyyy")) <strong>chưa đặt cơm cán bộ</strong>.</h5>
                        <p>Bấm nút "Báo cơm mới" để bắt đầu báo cơm cho ngày hôm nay.</p>
                    </div>
                }

                <!-- Bảng dữ liệu -->
                <div class="table-responsive">
                    <table class="table table-bordered table-hover">
                        <thead class="thead-dark">
                            <tr>
                                <th>STT</th>
                                <th>TT Chi phí</th>
                                <th>Mã cán bộ</th>
                                <th>Họ tên</th>
                                <th>Bộ phận</th>
                                <th>Món ăn</th>
                                <th>Trạng thái</th>
                                @*<th>Người tạo</th>*@
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                int stt = 1;
                            }
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>@stt</td>
                                    <td>@item.CostCenter</td>
                                    <td>@item.EmployeeId</td>
                                    <td>@item.FullName</td>
                                    <td>@item.DepartmentName</td>
                                    <td>
                                        <span class="badge @(item.MealName == "Cơm chay" ? "badge-success" : "badge-warning")">
                                            @item.MealName
                                        </span>
                                    </td>
                                    <td>
                                        <span class="badge @(item.Status == "Đặt" ? "badge-info" : "badge-danger")">
                                            @item.Status
                                        </span>
                                    </td>
                                    @*<td>@item.Creator</td>*@
                                    <td>
                                        @if (item.OrderId.HasValue)
                                        {
                                            @Html.ActionLink("Sửa", "Edit", new { id = item.OrderId, employeeId = item.EmployeeId, date = item.Date.ToString("yyyy-MM-dd") }, new { @class = "btn btn-sm btn-warning" })
                                        }
                                        else
                                        {
                                            @Html.ActionLink("Đặt cơm", "Edit", new { employeeId = item.EmployeeId, date = item.Date.ToString("yyyy-MM-dd") }, new { @class = "btn btn-sm btn-success" })
                                        }
                                    </td>
                                </tr>
                                stt++;
                            }
                        </tbody>
                    </table>
                </div>

                @if (!Model.Any() && ViewBag.NoOrderToday == null)
                {
                    <div class="alert alert-info">Chưa có báo cơm cho ngày này.</div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")

    <script>
        -
    flatpickr("#datePicker", {

        dateFormat: "Y-m-d",

        defaultDate: "@ViewBag.SelectedDate.ToString("yyyy-MM-dd")",

        onChange: function(selectedDates, dateStr) {

            window.location.href = '/LeaderOrders/Index?date=' + dateStr;

        }

    });

    </script>
}