@model CanteenSystem.Models.LeaderOrder

@{
    ViewBag.Title = "Chỉnh sửa báo cơm cán bộ";
    var date = (DateTime)ViewBag.Date;
    var employeeName = (string)ViewBag.EmployeeName;
}

<div class="content">
    <div class="container-fluid">
        <div class="card">
            <div class="card-header bg-warning text-dark">
                <h4><i class="fas fa-edit"></i> Chỉnh sửa báo cơm - @employeeName</h4>
                <small>Ngày: @date.ToString("dd/MM/yyyy")</small>
            </div>
            <div class="card-body">
                @using (Html.BeginForm())
                {
                    @Html.AntiForgeryToken()
                    @Html.HiddenFor(model => model.OrderId)
                    @Html.HiddenFor(model => model.EmployeeId)
                    @Html.HiddenFor(model => model.Date)
                    @Html.HiddenFor(model => model.CreatedAt)
                    @Html.HiddenFor(model => model.Creator)

                    <div class="form-group">
                        <label>Món ăn</label>
                        @Html.DropDownListFor(model => model.MealId, (SelectList)ViewBag.Meals, "-- Chọn món --", new { @class = "form-control" })
                        @Html.ValidationMessageFor(model => model.MealId, "", new { @class = "text-danger" })
                    </div>

                    <div class="form-group">
                        <label>Trạng thái</label>
                        @Html.DropDownListFor(model => model.Status, new SelectList(new[] { "Chưa đặt", "Đặt" }, Model.Status), new { @class = "form-control" })
                        @Html.ValidationMessageFor(model => model.Status, "", new { @class = "text-danger" })
                    </div>

                    <div class="form-group">
                        <label>Giá (VNĐ)</label>
                        @Html.TextBoxFor(model => model.Price, new { @class = "form-control", @readonly = "readonly" })
                    </div>

                    <div class="text-center mt-4">
                        <input type="submit" value="Lưu thay đổi" class="btn btn-warning" />
                        <a href="@Url.Action("Index", new { date = date })" class="btn btn-secondary ml-2">Quay lại danh sách</a>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

    @section Scripts {
        @Scripts.Render("~/bundles/jqueryval")
    }
